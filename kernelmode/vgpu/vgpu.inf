;
; vgpu.inf
;

[Version]
Signature="$WINDOWS NT$"
Class=System
ClassGUID={4d36e97d-e325-11ce-bfc1-08002be10318}
Provider=%ManufacturerName%
CatalogFile=vgpu.cat
DriverVer= ; TODO: set DriverVer in stampinf property pages
PnpLockDown=1

[DestinationDirs]
DefaultDestDir = 12
vgpu_Device_CoInstaller_CopyFiles = 11

; ================= Class section =====================

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
vgpu.sys  = 1,,
WdfCoInstaller$KMDFCOINSTALLERVERSION$.dll=1 ; make sure the number matches with SourceDisksNames

;*****************************************
; Install Section
;*****************************************

[Manufacturer]
%ManufacturerName%=Standard,NT$ARCH$

[Standard.NT$ARCH$]
%vgpu.DeviceDesc%=vgpu_Device, PCI\VEN_1AF4&DEV_1050&SUBSYS_11001AF4&REV_01, PCI\VEN_1AF4&DEV_1050

[vgpu_Device.NT]
CopyFiles=Drivers_Dir

[vgpu_Device.NT.HW]
AddReg=MSI_Interrupts

[Drivers_Dir]
vgpu.sys

[MSI_Interrupts]
HKR,Interrupt Management,,0x00000010
HKR,Interrupt Management\MessageSignaledInterruptProperties,,0x00000010
HKR,Interrupt Management\MessageSignaledInterruptProperties,MSISupported,0x00010001,1
HKR,Interrupt Management\MessageSignaledInterruptProperties,MessageNumberLimit,0x00010001,4

;-------------- Service installation
[vgpu_Device.NT.Services]
AddService = vgpu,%SPSVCINST_ASSOCSERVICE%, vgpu_Service_Inst

; -------------- vgpu driver install sections
[vgpu_Service_Inst]
DisplayName    = %vgpu.SVCDESC%
ServiceType    = 1               ; SERVICE_KERNEL_DRIVER
StartType      = 3               ; SERVICE_DEMAND_START
ErrorControl   = 1               ; SERVICE_ERROR_NORMAL
ServiceBinary  = %12%\vgpu.sys

;
;--- vgpu_Device Coinstaller installation ------
;

[vgpu_Device.NT.CoInstallers]
AddReg=vgpu_Device_CoInstaller_AddReg
CopyFiles=vgpu_Device_CoInstaller_CopyFiles

[vgpu_Device_CoInstaller_AddReg]
HKR,,CoInstallers32,0x00010000, "WdfCoInstaller$KMDFCOINSTALLERVERSION$.dll,WdfCoInstaller"

[vgpu_Device_CoInstaller_CopyFiles]
WdfCoInstaller$KMDFCOINSTALLERVERSION$.dll

[vgpu_Device.NT.Wdf]
KmdfService =  vgpu, vgpu_wdfsect
[vgpu_wdfsect]
KmdfLibraryVersion = $KMDFVERSION$

[Strings]
SPSVCINST_ASSOCSERVICE= 0x00000002
ManufacturerName="Avatar Imaging"
ClassName="VirtIO GPU 3D"
DiskName = "VirtIO GPU 3D Driver Installation Disk"
vgpu.DeviceDesc = "VirtIO GPU 3D (VirGL)"
vgpu.SVCDESC = "VirtIO GPU 3D Service"
